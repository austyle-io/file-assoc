# macOS File Association Configuration
# Format: bundle_id  UTI/extension  role
# Roles: all (default), editor, viewer, shell
#
# Apply with: duti config/macos-file-associations.duti
# List current associations: duti -x <extension>
#
# Bundle ID for VS Code: com.microsoft.VSCode

# Development Files - VS Code (primary editor)
com.microsoft.VSCode  .json       all
com.microsoft.VSCode  .jsonc      all
com.microsoft.VSCode  .json5      all
com.microsoft.VSCode  .yaml       all
com.microsoft.VSCode  .yml        all
com.microsoft.VSCode  .toml       all
com.microsoft.VSCode  .md         all
com.microsoft.VSCode  .markdown   all
com.microsoft.VSCode  .txt        all
com.microsoft.VSCode  .log        all

# Shell Scripts - VS Code
com.microsoft.VSCode  .sh         all
com.microsoft.VSCode  .bash       all
com.microsoft.VSCode  .zsh        all
com.microsoft.VSCode  .fish       all
com.microsoft.VSCode  public.shell-script  all

# Programming Languages - VS Code
com.microsoft.VSCode  .ts         all
com.microsoft.VSCode  .tsx        all
com.microsoft.VSCode  .js         all
com.microsoft.VSCode  .jsx        all
