# Templates - VS Code
com.microsoft.VSCode  .tmpl       all
com.microsoft.VSCode  .j2         all

# Diffs / Patches - VS Code
com.microsoft.VSCode  .diff       all
com.microsoft.VSCode  .patch      all

# Plain Text - VS Code (editor role; keeps system default opener)
com.microsoft.VSCode  public.plain-text  editor
com.microsoft.VSCode  public.text  editor

# CSV/TSV - VS Code (editor role; Numbers/Excel stays default)
com.microsoft.VSCode  .csv        editor
com.microsoft.VSCode  .tsv        editor

# XML - VS Code (HTML excluded - system protected)
com.microsoft.VSCode  .xml        all

# SVG - VS Code (editor role; Preview/browser stays default viewer)
com.microsoft.VSCode  .svg        editor

# SQL - VS Code
com.microsoft.VSCode  .sql        all

# Docker - VS Code
com.microsoft.VSCode  Dockerfile  all
com.microsoft.VSCode  .dockerfile  all

# Container and CI/CD configs - VS Code
com.microsoft.VSCode  .dockerignore  all
